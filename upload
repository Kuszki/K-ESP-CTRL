#!/bin/bash

CHIP="none"
ROLE="none"

PORT="ttyUSB0"

DO_FEECH=false
DO_FLASH=false
DO_REPL=false
DO_BUILD=false

IS_FIRST=true

while [ "$1" != "" ]; do

	PARAM=`echo $1 | awk -F= '{print $1}'`
	VALUE=`echo $1 | awk -F= '{print $2}'`

	case $PARAM in

		-m | --mcu)
			CHIP=$VALUE
			;;

		-t | --type)
			ROLE=$VALUE
			;;
			
		-p | --port)
			PORT=$VALUE
			;;

		-d | --download)
			DO_FEECH=true
			;;

		-f | --flash)
			DO_FLASH=true
			;;
			
		-r | --repl)
			DO_REPL=true
			;;
			
		-b | --build)
			DO_BUILD=true
			;;
			
		-c | --client)
			ROLE="client"
			;;
			
		-s | --server)
			ROLE="server"
			;;

	esac
	shift

done

if [ $DO_BUILD == true ] || [ "$ROLE" != "none" ]
then
	for f in lib/*.py
	do
		mpy-cross -O3 -march=xtensa $f
	done
fi

if [ $DO_FEECH == true ]
then
	wget -qO- "https://code.jquery.com/jquery-1.11.1.min.js"                | gzip -9 > "arch/jquery.js.gz"
	wget -qO- "https://cdn.jsdelivr.net/npm/moment@2.30.1/moment.min.js"    | gzip -9 > "arch/moment.js.gz"
	wget -qO- "https://cdn.jsdelivr.net/npm/moment@2.30.1/locale/pl.min.js" | gzip -9 > "arch/moment.pl.js.gz"
	wget -qO- "https://cdn.jsdelivr.net/npm/chart.js@2.9.4"                 | gzip -9 > "arch/chart.js.gz"
	wget -qO- "https://cdn.jsdelivr.net/npm/hammerjs@2.0.8"                 | gzip -9 > "arch/hammer.js.gz"
	wget -qO- "https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@0.7.7"      | gzip -9 > "arch/chart.zoom.js.gz"
fi

if [ "$ROLE" == "server" ]
then
	printf "{\n" > "etc/etags.json"

	for f in obj/*.ico arch/*.gz http/*.html css/*.css src/*.js
	do
		if [ $IS_FIRST == true ]; then IS_FIRST=false; else printf ',\n' >> "etc/etags.json"; fi
		printf '\t"%s": "%s"' $(basename "$f") $(cksum "$f" | awk '{print $1}') >> "etc/etags.json"
	done
	
	printf "\n}" >> "etc/etags.json"
fi

if [ $DO_FLASH == true ] && [ "$CHIP" == "esp32" ]
then
	esptool --chip esp32 --port "/dev/$PORT" erase-flash
	sleep 1s
	esptool --chip esp32 --port "/dev/$PORT" --baud 460800 write-flash --flash-size=detect -z 0x1000 esp32.bin
fi

if [ $DO_FLASH == true ] && [ "$CHIP" == "esp8266" ]
then
	esptool --chip esp8266 --port "/dev/$PORT" erase-flash
	sleep 1s
	esptool --chip esp8266 --port "/dev/$PORT" --baud 460800 write-flash --flash-size=detect -fm dio 0 esp8266.bin
fi

if [ "$ROLE" == "server" ]
then
	mpfshell "$PORT" -s server.mpf
fi

if [ "$ROLE" == "client" ]
then
	mpfshell "$PORT" -s client.mpf
fi

if [ $DO_BUILD == false ]
then
	rm -f lib/*.mpy
fi

if [ $DO_REPL == true ]
then
	mpfshell "$PORT" -c repl
fi
